<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--
    Common differential-drive base: cylindrical chassis, two driven wheels, one caster.
    Args:
      prefix: unique link/joint prefix, e.g. robot_a_
      chassis_rgba: visual color
  -->
  <xacro:property name="chassis_radius" value="0.16"/>
  <xacro:property name="chassis_height" value="0.07"/>
  <!-- Higher mass reduces "coin on edge" tipping in ODE. -->
  <xacro:property name="chassis_mass" value="4.5"/>
  <xacro:property name="wheel_radius" value="0.036"/>
  <xacro:property name="wheel_width" value="0.02"/>
  <xacro:property name="wheel_mass" value="0.08"/>
  <xacro:property name="wheel_sep" value="0.24"/>
  <xacro:property name="caster_radius" value="0.018"/>
  <xacro:property name="caster_mass" value="0.02"/>

  <xacro:macro name="cylinder_inertial" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m * (3*r*r + h*h) / 12}" ixy="0.0" ixz="0.0"
               iyy="${m * (3*r*r + h*h) / 12}" iyz="0.0"
               izz="${m * r*r / 2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="wheel_inertial" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m * (3*r*r + h*h) / 12}" ixy="0.0" ixz="0.0"
               iyy="${m * (3*r*r + h*h) / 12}" iyz="0.0"
               izz="${m * r*r / 2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertial" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${0.4*m*r*r}" ixy="0.0" ixz="0.0"
               iyy="${0.4*m*r*r}" iyz="0.0"
               izz="${0.4*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="roomba_base" params="prefix chassis_rgba">
    <link name="${prefix}base_link">
      <xacro:cylinder_inertial m="${chassis_mass}" r="${chassis_radius}" h="${chassis_height}"/>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${chassis_height}" radius="${chassis_radius}"/>
        </geometry>
        <material name="${prefix}chassis_mat">
          <color rgba="${chassis_rgba}"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${chassis_height}" radius="${chassis_radius}"/>
        </geometry>
      </collision>
    </link>

    <!-- Wheels: same convention as libgazebo_ros_diff_drive demo (spin axis matches plugin). -->
    <link name="${prefix}left_wheel_link">
      <xacro:wheel_inertial m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
        </geometry>
        <material name="${prefix}wheel_mat"><color rgba="0.1 0.1 0.1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}right_wheel_link">
      <xacro:wheel_inertial m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
        </geometry>
        <material name="${prefix}wheel_mat2"><color rgba="0.1 0.1 0.1 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}caster_link">
      <xacro:sphere_inertial m="${caster_mass}" r="${caster_radius}"/>
      <visual>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="${prefix}caster_mat"><color rgba="0.3 0.3 0.3 1"/></material>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}left_wheel_link"/>
      <origin xyz="0 ${wheel_sep/2} ${-chassis_height/2 + wheel_radius}" rpy="-1.57079632679 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.02" friction="0.05"/>
    </joint>

    <joint name="${prefix}right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}right_wheel_link"/>
      <origin xyz="0 ${-wheel_sep/2} ${-chassis_height/2 + wheel_radius}" rpy="-1.57079632679 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.02" friction="0.05"/>
    </joint>

    <!--
      Caster height: ball rim should match wheel contact height.
      Old: center at z=-h/2 rim ~-0.053 (below wheels) -> wheels floating.
      Now: center at z=-h/2+R_wheel-R_caster -> rim aligned with wheels.
    -->
    <joint name="${prefix}caster_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}caster_link"/>
      <origin xyz="-${chassis_radius*0.55} 0 ${-chassis_height/2 + wheel_radius - caster_radius}" rpy="0 0 0"/>
    </joint>

    <gazebo reference="${prefix}base_link">
      <material>Gazebo/Grey</material>
      <mu1>0.9</mu1><mu2>0.9</mu2>
    </gazebo>
    <gazebo reference="${prefix}left_wheel_link">
      <material>Gazebo/Black</material>
      <mu1>1.8</mu1><mu2>1.8</mu2>
      <kp>500000.0</kp>
      <kd>20.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>10.0</maxVel>
    </gazebo>
    <gazebo reference="${prefix}right_wheel_link">
      <material>Gazebo/Black</material>
      <mu1>1.8</mu1><mu2>1.8</mu2>
      <kp>500000.0</kp>
      <kd>20.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>10.0</maxVel>
    </gazebo>
    <gazebo reference="${prefix}caster_link">
      <material>Gazebo/Black</material>
      <mu1>0.6</mu1><mu2>0.6</mu2>
      <kp>100000.0</kp>
      <kd>10.0</kd>
    </gazebo>
  </xacro:macro>
</robot>
